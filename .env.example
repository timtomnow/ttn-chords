# Copy to `.env.local` and fill in from Supabase -> Project Settings -> API.
# `.env.local` is git-ignored; this example file is committed and holds NO secrets.
#
# Only the URL and the ANON / publishable key belong in any frontend env file.
# The service-role / secret key must NEVER appear here — it lives only in
# Supabase Edge Function secrets.

# `npm run dev` should point at the DEV Supabase project (ttn-chords-dev).
# The production build points at the PROD project (set in the deploy's build env).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: set to 'true' to show Google/Apple sign-in buttons. Leave unset until
# the matching OAuth providers are enabled in Supabase -> Authentication.
# VITE_ENABLE_SOCIAL_AUTH=true
